# Frontend (Vite) configuration.
# Copy this file to `.env` and adjust as needed. Only VITE_-prefixed vars are
# exposed to the React app via import.meta.env. The real `.env` is git-ignored.

# Base URL of the Python sidecar (FastAPI). Must match the sidecar's host/port.
VITE_SIDECAR_URL=http://127.0.0.1:8765
