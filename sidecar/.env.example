# Lore sidecar configuration.
# Copy this file to `.env` and adjust as needed. The real `.env` is git-ignored;
# only this template is committed. All variables are prefixed LORE_.

# HTTP server binding (loopback only by default).
LORE_HOST=127.0.0.1
LORE_PORT=8765

# Directory for the embedded stores (LanceDB + SQLite). Created at runtime.
LORE_DATA_DIR=data

# Ollama runtime and model names.
LORE_OLLAMA_URL=http://127.0.0.1:11434
LORE_GENERATION_MODEL=qwen3:8b
LORE_EMBEDDING_MODEL=nomic-embed-text

# ONNX cross-encoder reranker (via fastembed). The default is small and loads
# alongside the LLM; use "BAAI/bge-reranker-base" for higher quality if you have
# the RAM (it is ~1 GB and can fail to load on memory-constrained machines).
LORE_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
